{
  "venvPath": "services/transcribe",
  "venv": ".venv",
  "executionEnvironments": [
    {
      "root": "services/transcribe",
      "extraPaths": [
        "services/exports/src",
        "services/transcribe/src"
      ]
    },
    {
      "root": "services/api",
      "extraPaths": [
        "services/exports/src",
        "services/api/src"
      ]
    },
    {
      "root": "services/exports",
      "extraPaths": ["services/exports/src"]
    },
    {
      "root": "services/media_processor",
      "extraPaths": [
        "services/exports/src",
        "services/media_processor/src",
        "services/media_processor/.venv/lib/python3.13/site-packages"
      ]
    },
    {
      "root": "services/caption",
      "extraPaths": [
        "services/exports/src",
        "services/caption/src"
      ]
    }
  ]
}
